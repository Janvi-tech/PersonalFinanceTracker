<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <title>Register - Personal Finance Tracker</title>
</head>

<body>

    <h2>Create Account</h2>

    <p th:if="${error}"
       th:text="${error}"
       style="color: red;">
    </p>

    <form th:action="@{/register}"
          th:object="${user}"
          method="post">

        <label>Full Name:</label>
        <input type="text"
               th:field="*{fullName}"
               required>

        <br><br>

        <label>Username:</label>
        <input type="text"
               th:field="*{username}"
               required>

        <br><br>

        <label>Email:</label>
        <input type="email"
               th:field="*{email}"
               required>

        <br><br>

        <label>Password:</label>
        <input type="password"
               th:field="*{password}"
               required>

        <br><br>

        <button type="submit">
            Register
        </button>

    </form>

    <p>
        Already have an account?
        <a href="/login">Login</a>
    </p>

</body>

</html>