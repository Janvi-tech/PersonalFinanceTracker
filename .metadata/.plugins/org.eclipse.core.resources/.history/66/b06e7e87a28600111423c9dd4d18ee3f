<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

    <title>Dashboard - Personal Finance Tracker</title>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <link rel="stylesheet"
          th:href="@{/css/style.css}">

</head>


<body>

    <!-- Navbar -->

    <div th:replace="~{fragments/navbar :: navbar}">
    </div>


    <main class="container">

        <h1>Personal Finance Dashboard</h1>


        <!-- Dashboard Cards -->

        <div class="dashboard-cards">

            <div class="card">

                <h3>Total Income</h3>

                <p>
                    ₹
                    <span th:text="${totalIncome}">
                        0
                    </span>
                </p>

            </div>


            <div class="card">

                <h3>Total Expenses</h3>

                <p>
                    ₹
                    <span th:text="${totalExpense}">
                        0
                    </span>
                </p>

            </div>


            <div class="card">

                <h3>Current Balance</h3>

                <p>
                    ₹
                    <span th:text="${balance}">
                        0
                    </span>
                </p>

            </div>

        </div>


        <br>


        <!-- Expense Category Chart -->

        <div class="chart-container">

            <h2>Expense by Category</h2>

            <canvas id="expenseChart">
            </canvas>

        </div>


        <br>


        <!-- Income vs Expense Chart -->

        <div class="chart-container">

            <h2>Income vs Expense</h2>

            <canvas id="incomeExpenseChart">
            </canvas>

        </div>


        <br>


        <!-- Monthly Summary -->

        <h2>Monthly Summary</h2>


        <form action="/dashboard/monthly"
              method="get">

            <label>
                Select Month:
            </label>


            <select name="month">

                <option value="1">January</option>

                <option value="2">February</option>

                <option value="3">March</option>

                <option value="4">April</option>

                <option value="5">May</option>

                <option value="6">June</option>

                <option value="7">July</option>

                <option value="8">August</option>

                <option value="9">September</option>

                <option value="10">October</option>

                <option value="11">November</option>

                <option value="12">December</option>

            </select>


            <label>
                Year:
            </label>


            <input type="number"
                   name="year"
                   value="2026"
                   min="2000"
                   max="2100">


            <button type="submit">

                View Summary

            </button>

        </form>


        <br>


        <!-- Monthly Chart -->

        <div class="chart-container">

            <h2>Selected Month Analysis</h2>

            <canvas id="monthlyChart">
            </canvas>

        </div>


    </main>


    <!-- Chart JavaScript -->

    <script th:inline="javascript">

        // Expense data from Spring Boot

        const expenseData =
            /*[[${expenseData}]]*/ [];


        const categories =
            expenseData.map(item => item[0]);


        const amounts =
            expenseData.map(item => item[1]);


        // Expense by Category Chart

        new Chart(

            document.getElementById("expenseChart"),

            {

                type: "doughnut",

                data: {

                    labels: categories,

                    datasets: [{

                        label: "Expenses",

                        data: amounts

                    }]

                },

                options: {

                    responsive: true

                }

            }

        );


        // Total Income and Expense

        const totalIncome =
            /*[[${totalIncome}]]*/ 0;


        const totalExpense =
            /*[[${totalExpense}]]*/ 0;


        // Income vs Expense Chart

        new Chart(

            document.getElementById("incomeExpenseChart"),

            {

                type: "bar",

                data: {

                    labels: [

                        "Income",

                        "Expense"

                    ],

                    datasets: [{

                        label: "Amount",

                        data: [

                            totalIncome,

                            totalExpense

                        ]

                    }]

                },

                options: {

                    responsive: true,

                    scales: {

                        y: {

                            beginAtZero: true

                        }

                    }

                }

            }

        );


        // Monthly Income

        const monthlyIncome =
            /*[[${totalIncome}]]*/ 0;


        // Monthly Expense

        const monthlyExpense =
            /*[[${totalExpense}]]*/ 0;


        // Monthly Chart

        new Chart(

            document.getElementById("monthlyChart"),

            {

                type: "bar",

                data: {

                    labels: [

                        "Income",

                        "Expense"

                    ],

                    datasets: [{

                        label: "Monthly Amount",

                        data: [

                            monthlyIncome,

                            monthlyExpense

                        ]

                    }]

                },

                options: {

                    responsive: true,

                    scales: {

                        y: {

                            beginAtZero: true

                        }

                    }

                }

            }

        );

    </script>

</body>

</html>