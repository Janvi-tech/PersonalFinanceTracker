<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

    <title>Budget Management</title>
	<link rel="stylesheet" th:href="@{/css/style.css}">

</head>

<body>

    <div th:replace="~{fragments/navbar :: navbar}"></div>

    <h1>Budget Management</h1>

    <h2>Set Budget</h2>

    <form th:action="@{/budgets/add}"
          th:object="${budget}"
          method="post">

        <label>Category:</label>

        <select th:field="*{category}" required>

            <option value="">Select Category</option>
            <option value="Food">Food</option>
            <option value="Travel">Travel</option>
            <option value="Shopping">Shopping</option>
            <option value="Bills">Bills</option>
            <option value="Entertainment">
                Entertainment
            </option>
            <option value="Healthcare">
                Healthcare
            </option>
            <option value="Other">Other</option>

        </select>

        <br><br>

        <label>Budget Amount:</label>

        <input type="number"
               th:field="*{amount}"
               step="0.01"
			   min="1",
               required>

        <br><br>

        <label>Month:</label>

        <select th:field="*{month}" required>

            <option value="1">January</option>
            <option value="2">February</option>
            <option value="3">March</option>
            <option value="4">April</option>
            <option value="5">May</option>
            <option value="6">June</option>
            <option value="7">July</option>
            <option value="8">August</option>
            <option value="9">September</option>
            <option value="10">October</option>
            <option value="11">November</option>
            <option value="12">December</option>

        </select>

        <br><br>

        <label>Year:</label>

        <input type="number"
               th:field="*{year}"
               value="2026"
               required>

        <br><br>

        <button type="submit">
            Set Budget
        </button>

    </form>
	
	<hr>

	<h2>Budget Analysis</h2>

	<table border="1">

	    <tr>
	        <th>Category</th>
	        <th>Budget</th>
	        <th>Spent</th>
	        <th>Remaining</th>
	        <th>Used %</th>
	    </tr>

	    <tr th:each="summary : ${summaryList}">

	        <td th:text="${summary.category}">
	        </td>

	        <td th:text="${summary.budgetAmount}">
	        </td>

	        <td th:text="${summary.spentAmount}">
	        </td>

	        <td th:text="${summary.remainingAmount}">
	        </td>

	        <td>
	            <span th:text="${summary.utilizationPercentage + '%'}"></span>
	        </td>

	    </tr>

	</table>

    <hr>

    <h2>Budget List</h2>

    <table border="1">

        <tr>

            <th>Category</th>
            <th>Amount</th>
            <th>Month</th>
            <th>Year</th>
            <th>Action</th>

        </tr>

        <tr th:each="budget : ${budgetList}">

            <td th:text="${budget.category}"></td>

            <td th:text="${budget.amount}"></td>

            <td th:text="${budget.month}"></td>

            <td th:text="${budget.year}"></td>

            <td>

                <a th:href="@{/budgets/delete/{id}
                    (id=${budget.id})}">
                    Delete
                </a>

            </td>

        </tr>

    </table>

</body>

</html>