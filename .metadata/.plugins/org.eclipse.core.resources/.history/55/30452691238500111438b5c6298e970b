<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

    <title>Expenses</title>

</head>

<body>
	<div th:replace="~{fragments/navbar :: navbar}"></div>
    <h1>Expense Management</h1>

    <h2>Add Expense</h2>

    <form th:action="@{/expenses/add}"
          th:object="${expense}"
          method="post">

        <label>Category:</label>

        <select th:field="*{category}" required>

            <option value="">Select Category</option>

            <option value="Food">Food</option>

            <option value="Travel">Travel</option>

            <option value="Shopping">Shopping</option>

            <option value="Bills">Bills</option>

            <option value="Entertainment">
                Entertainment
            </option>

            <option value="Healthcare">
                Healthcare
            </option>

            <option value="Other">Other</option>

        </select>

        <br><br>

        <label>Amount:</label>

        <input type="number"
               th:field="*{amount}"
               step="0.01"
               required>

        <br><br>

        <label>Date:</label>

        <input type="date"
               th:field="*{expenseDate}"
               required>

        <br><br>

        <label>Description:</label>

        <input type="text"
               th:field="*{description}">

        <br><br>

        <button type="submit">
            Add Expense
        </button>

    </form>

    <hr>

    <h2>Expense History</h2>

    <table border="1">

        <tr>

            <th>Category</th>
            <th>Amount</th>
            <th>Date</th>
            <th>Description</th>
            <th>Action</th>

        </tr>

        <tr th:each="expense : ${expenseList}">

            <td th:text="${expense.category}"></td>

            <td th:text="${expense.amount}"></td>

            <td th:text="${expense.expenseDate}"></td>

            <td th:text="${expense.description}"></td>

            <td>

                <a th:href="@{/expenses/delete/{id}
                        (id=${expense.id})}">
                    Delete
                </a>

            </td>

        </tr>

    </table>

    <br>

    <a href="/dashboard">
        Back to Dashboard
    </a>

</body>

</html>