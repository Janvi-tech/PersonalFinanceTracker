* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, sans-serif;
    background: #f4f6f9;
    color: #333;
}

/* Navigation */

.navbar {
    background: #1f2937;
    padding: 18px 30px;
    display: flex;
    align-items: center;
    gap: 25px;
}

.navbar a {
    color: white;
    text-decoration: none;
    font-weight: bold;
}

.navbar a:hover {
    color: #60a5fa;
}

.logout-button {
    background: #dc2626;
    color: white;
    border: none;
    padding: 8px 15px;
    border-radius: 5px;
    cursor: pointer;
}

/* Main Container */

.container {
    padding: 30px;
}

/* Dashboard Cards */

.dashboard-cards {
    display: flex;
    gap: 20px;
    margin-top: 25px;
}

.card {
    background: white;
    padding: 25px;
    border-radius: 12px;
    width: 250px;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
}

.card h3 {
    margin-bottom: 12px;
    color: #555;
}

.card p {
    font-size: 24px;
    font-weight: bold;
}

/*--------------------------------------------------------*/
/* Forms */

.form-container {
    background: white;
    padding: 25px;
    border-radius: 12px;
    max-width: 600px;
    margin-top: 25px;
}

input,
select {
    width: 100%;
    padding: 10px;
    margin-top: 6px;
    border: 1px solid #ccc;
    border-radius: 5px;
}

button {
    padding: 10px 18px;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    background: #2563eb;
    color: white;
}

/* Tables */

table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 25px;
    background: white;
}

th,
td {
    padding: 12px;
    border-bottom: 1px solid #ddd;
    text-align: left;
}

th {
    background: #1f2937;
    color: white;
}

tr:hover {
    background: #f1f5f9;
}

/* Charts */

.chart-container {
    background: white;
    padding: 25px;
    margin-top: 25px;
    border-radius: 12px;
    max-width: 700px;
}