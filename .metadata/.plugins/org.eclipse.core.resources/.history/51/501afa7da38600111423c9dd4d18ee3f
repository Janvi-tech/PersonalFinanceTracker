<body>

<div th:replace="~{fragments/navbar :: navbar}"></div>

<div class="container">

    <h1>Personal Finance Dashboard</h1>

    <p>
        Welcome,
        <b th:text="${#authentication.name}"></b>
    </p>

    <!-- Summary Cards -->

    <div class="dashboard-grid">

        <div class="dashboard-card income">

            <h3>Total Income</h3>

            <h2>
                ₹<span th:text="${totalIncome}"></span>
            </h2>

        </div>

        <div class="dashboard-card expense">

            <h3>Total Expenses</h3>

            <h2>
                ₹<span th:text="${totalExpense}"></span>
            </h2>

        </div>

        <div class="dashboard-card balance">

            <h3>Current Balance</h3>

            <h2>
                ₹<span th:text="${balance}"></span>
            </h2>

        </div>

        <div class="dashboard-card budget">

            <h3>Budget Status</h3>

            <h2>Active</h2>

        </div>

    </div>

    <br>

    <!-- Charts -->

    <div class="chart-row">

        <div class="chart-box">

            <h2>Income vs Expense</h2>

            <canvas id="incomeExpenseChart"></canvas>

        </div>

        <div class="chart-box">

            <h2>Expense by Category</h2>

            <canvas id="expenseChart"></canvas>

        </div>

    </div>

    <br>

    <!-- Monthly Analysis -->

    <div class="chart-box">

        <h2>Monthly Analysis</h2>

        <form action="/dashboard/monthly" method="get">

            <select name="month">

                <option value="1">January</option>
                <option value="2">February</option>
                <option value="3">March</option>
                <option value="4">April</option>
                <option value="5">May</option>
                <option value="6">June</option>
                <option value="7">July</option>
                <option value="8">August</option>
                <option value="9">September</option>
                <option value="10">October</option>
                <option value="11">November</option>
                <option value="12">December</option>

            </select>

            <input type="number"
                   name="year"
                   value="2026">

            <button type="submit">
                View
            </button>

        </form>

        <br>

        <canvas id="monthlyChart"></canvas>

    </div>

</div>

</body>